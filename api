# bot.py
import requests
from collections import defaultdict
from telegram import Update, InlineKeyboardButton, InlineKeyboardMarkup, Bot
from telegram.ext import ApplicationBuilder, CommandHandler, MessageHandler, CallbackQueryHandler, ContextTypes, filters
import threading, time

TOKEN = "8329367413:AAGk3irV5U-61lm44PyMN_NVDaTS1Mi8s-s"
bot = Bot(TOKEN)

all_words = []
words_index = defaultdict(list)

def load_kbbi():
    global all_words, words_index
    url = "https://raw.githubusercontent.com/ftshk/kbbi-wordlist/main/kbbi.txt"
    r = requests.get(url)
    all_words = r.text.splitlines()
    words_index = defaultdict(list)
    for w in all_words:
        if w:
            words_index[w[0]].append(w)
    print(f"{len(all_words)} kata dimuat dari GitHub.")

def auto_update(interval=86400):
    while True:
        load_kbbi()
        time.sleep(interval)

def search_fast(start=None,end=None,contains=None):
    if start:
        possible = words_index.get(start[0],[])
        filtered = [w for w in possible if w.startswith(start)]
    else:
        filtered = all_words
    if end: filtered=[w for w in filtered if w.endswith(end)]
    if contains: filtered=[w for w in filtered if contains in w]
    return filtered

async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    keyboard = [[InlineKeyboardButton("Owner", callback_data="owner")],
                [InlineKeyboardButton("Donate", callback_data="donate")]]
    reply_markup = InlineKeyboardMarkup(keyboard)
    await update.message.reply_text(
        "Halo! Bot Pencari Kata KBBI siap pakai.\nFormat:\n- kata_awal\n- kata_awal kata_akhir\n- *kata*",
        reply_markup=reply_markup
    )

async def button_callback(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    if query.data=="owner":
        await query.edit_message_text("Owner Bot: @KanjengXd")
    elif query.data=="donate":
        await query.edit_message_text("Support Bot: DANA/GOPAY 0831-9004-7874")

async def handle_message(update: Update, context: ContextTypes.DEFAULT_TYPE):
    text=update.message.text.strip()
    contains=None; start_word=None; end_word=None
    if text.startswith("*") and text.endswith("*"):
        contains=text.strip("*")
    else:
        parts=text.split()
        if len(parts)==1: start_word=parts[0]
        elif len(parts)==2: start_word,end_word=parts
        else:
            await update.message.reply_text("Format salah!"); return
    results=search_fast(start_word,end_word,contains)
    if not results: await update.message.reply_text("Tidak ada kata ditemukan."); return
    reply_text="\n".join(results)
    await update.message.reply_text(reply_text)

def main():
    load_kbbi()
    threading.Thread(target=auto_update,daemon=True).start()
    app=ApplicationBuilder().token(TOKEN).build()
    app.add_handler(CommandHandler("start",start))
    app.add_handler(CallbackQueryHandler(button_callback))
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND,handle_message))
    print("Bot berjalan...")
    app.run_polling()

if __name__=="__main__":
    main()
